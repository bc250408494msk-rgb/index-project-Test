# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=3001

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://indexmenow:indexmenow_secret@localhost:5432/indexmenow

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=minimum-32-character-random-secret-change-this-in-production
JWT_REFRESH_SECRET=different-minimum-32-character-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Email (Resend — FREE: 3k/month) ──────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=IndexMeNow

# ── Google Service Account (Indexing API + GSC URL Inspect) ──
# Paste the full JSON key as a single line OR provide path to file
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── Google APIs (FREE quotas) ─────────────────────────────────
GOOGLE_CUSTOM_SEARCH_API_KEY=AIzaSy_your_key_here
GOOGLE_CUSTOM_SEARCH_CX=0123456789abcdef0
GOOGLE_SAFE_BROWSING_API_KEY=AIzaSy_your_safe_browsing_key

# ── isindexed.com ─────────────────────────────────────────────
ISINDEXED_API_KEY=your_isindexed_api_key

# ── IndexNow (Bing — FREE) ────────────────────────────────────
INDEXNOW_KEY=your-random-uuid-key-here
INDEXNOW_KEY_URL=https://yourdomain.com/your-random-uuid-key-here.txt
INDEXNOW_ENABLED=true

# ── Sentry (FREE tier) ────────────────────────────────────────
SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# ── System Config ─────────────────────────────────────────────
REFUND_WINDOW_DAYS=10
RETRY_WINDOW_DAYS=7
LOW_CREDIT_DEFAULT_THRESHOLD=5
MAX_URLS_PER_BATCH=500
HEALTH_CHECK_TIMEOUT_MS=10000
MALWARE_CHECK_ENABLED=true
DOUBLE_VERIFY_INDEXED=true
VERIFICATION_METHOD=isindexed

# ════════════════════════════════════════════════════════════════
#  PRODUCTION ENV REFERENCE — Railway (dashboard.primewellmedsolutions.com)
# ════════════════════════════════════════════════════════════════
#  Architecture: Browser → Next.js Web service → (proxy) → API service
#  Postgres + Redis are provided by Railway plugins.
#
#  Set these in the Railway dashboard → each service → Variables tab.
#  This file is a REFERENCE only — do not commit real secrets.
# ════════════════════════════════════════════════════════════════


# ────────────────────────────────────────────────────────────────
#  API SERVICE  (the Fastify backend + workers)
# ────────────────────────────────────────────────────────────────

# ── Core (REQUIRED — app will not boot without these) ───────────
NODE_ENV=production
PORT=3001
# Railway auto-injects these two when you attach the Postgres/Redis plugins:
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}
# Any 32+ char random strings (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-32char-plus-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-32char-random-string
# Separate secret for cookie signing (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
COOKIE_SECRET=change-me-to-another-32char-plus-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Public site URL — used in emails, sitemaps, RSS feeds, IndexNow host
APP_URL=https://dashboard.primewellmedsolutions.com
# Browser origin(s) allowed by CORS (comma-separated). With the proxy this is
# same-origin, but keep it set for safety.
ALLOWED_ORIGINS=https://dashboard.primewellmedsolutions.com

# ── Admin seed (used by `prisma db seed`) ───────────────────────
ADMIN_EMAIL=msharaz2546@gmail.com
ADMIN_PASSWORD=change-this-strong-password

# ── Login gate ──────────────────────────────────────────────────
# true  = users must verify email before login (set this once email works)
# false = allow login without verification (use until Resend is configured)
REQUIRE_EMAIL_VERIFICATION=false

# ── Email (Resend) — REQUIRED for verify / reset / notifications ─
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Must be an address on a domain you've VERIFIED in Resend:
EMAIL_FROM=noreply@primewellmedsolutions.com
EMAIL_FROM_NAME=IndexMeNow

# ── Verification — REQUIRED or every URL auto-refunds at day 10 ──
# RECOMMENDED: Google Search Console URL Inspection (free, authoritative).
# Uses the GOOGLE_SERVICE_ACCOUNT_JSON below — no extra keys. The URL's domain
# must be a verified Search Console property with the service account as owner.
VERIFICATION_METHOD=gsc
DOUBLE_VERIFY_INDEXED=true
# Alternative — Google Custom Search (note: "search entire web" was removed for
# NEW engines in Jan 2026, so this only works for pre-2026 engines or specific
# configured domains):
#   VERIFICATION_METHOD=google_cse
#   GOOGLE_CUSTOM_SEARCH_API_KEY=AIzaSy_your_key_here
#   GOOGLE_CUSTOM_SEARCH_CX=0123456789abcdef0
# Alternative — isindexed.com (paid third-party):
#   VERIFICATION_METHOD=isindexed
#   ISINDEXED_API_KEY=your_isindexed_api_key

# ── Google Indexing API + GSC (the real indexing signals) ───────
# Full service-account JSON on ONE line. Add the service-account email as an
# Owner in each client's Google Search Console property.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com"}

# ── IndexNow (Bing / Yandex — free) ─────────────────────────────
INDEXNOW_ENABLED=true
INDEXNOW_KEY=your-random-uuid-key
INDEXNOW_KEY_URL=https://dashboard.primewellmedsolutions.com/your-random-uuid-key.txt

# ── Malware check (optional — set false to skip) ────────────────
MALWARE_CHECK_ENABLED=false
# GOOGLE_SAFE_BROWSING_API_KEY=AIzaSy_your_safe_browsing_key

# ── Tuning (optional — these are the defaults) ──────────────────
REFUND_WINDOW_DAYS=10
RETRY_WINDOW_DAYS=7
MAX_URLS_PER_BATCH=500
HEALTH_CHECK_TIMEOUT_MS=10000

# ── Error tracking (optional) ───────────────────────────────────
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz


# ────────────────────────────────────────────────────────────────
#  WEB SERVICE  (the Next.js frontend)
# ────────────────────────────────────────────────────────────────

NODE_ENV=production
# REQUIRED: Must be the SAME value as JWT_SECRET on the API service.
# Used by Next.js Edge middleware to verify login cookies.
# If omitted, middleware falls back to decode-only mode (app still works but less secure).
JWT_SECRET=same-value-as-api-service-jwt-secret
# Server-only: where the Next.js proxy forwards /api/* requests. Use the API
# service's Railway URL. MUST include https://.
INTERNAL_API_URL=https://index-project-api-production.up.railway.app
# Leave NEXT_PUBLIC_API_URL EMPTY so the browser uses same-origin /api/* (the proxy).
NEXT_PUBLIC_API_URL=
